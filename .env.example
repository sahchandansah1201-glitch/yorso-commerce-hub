# YORSO self-hosted target
YORSO_PUBLIC_APP_URL=http://localhost:8080
YORSO_API_URL=http://localhost:3000
YORSO_API_PORT=3000
ACCOUNT_REPOSITORY=memory

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=yorso
POSTGRES_USER=yorso_app
POSTGRES_PASSWORD=change-me-local-only
DATABASE_URL=postgres://yorso_app:change-me-local-only@localhost:6432/yorso
MIGRATION_DATABASE_URL=postgres://yorso_app:change-me-local-only@localhost:5432/yorso
MIGRATION_APPLIED_BY=local-operator

# PgBouncer
PGBOUNCER_PORT=6432
PGBOUNCER_DATABASE_URL=postgres://yorso_app:change-me-local-only@localhost:6432/yorso

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible / MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=yorso-local
S3_ACCESS_KEY_ID=change-me-local-only
S3_SECRET_ACCESS_KEY=change-me-local-only

# Auth/session secrets. Generate real secrets per environment.
YORSO_SESSION_SECRET=change-me-32-bytes-minimum
YORSO_JWT_SECRET=change-me-32-bytes-minimum

# Supabase prototype only. Do not use as production backend target.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
