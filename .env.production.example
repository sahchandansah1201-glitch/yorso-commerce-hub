# YORSO self-hosted production runtime
# Copy to the server-side environment manager and replace every change-me value.
# This file intentionally contains no hosted BaaS/SaaS application-backend settings.

NODE_ENV=production

# Public URLs
YORSO_PUBLIC_APP_URL=https://app.yorso.example
YORSO_API_URL=https://api.yorso.example
VITE_YORSO_API_URL=https://api.yorso.example
YORSO_API_PORT=3000

# API data source
ACCOUNT_REPOSITORY=postgres

# PostgreSQL through PgBouncer for application traffic
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=yorso
POSTGRES_USER=yorso_app
POSTGRES_PASSWORD=change-me-production-db-password
DATABASE_URL=postgres://yorso_app:change-me-production-db-password@pgbouncer:5432/yorso

# Direct PostgreSQL connection for migrations only
MIGRATION_DATABASE_URL=postgres://yorso_app:change-me-production-db-password@postgres:5432/yorso
MIGRATION_APPLIED_BY=production-operator

# PgBouncer
PGBOUNCER_PORT=6432
PGBOUNCER_DATABASE_URL=postgres://yorso_app:change-me-production-db-password@pgbouncer:5432/yorso

# Redis for cache, locks, sessions, rate limits and short-lived workflow state
REDIS_URL=redis://redis:6379

# Owned storage. Current API file storage uses a mounted server volume.
# MinIO/S3-compatible settings stay here for the owned object-storage boundary.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=/var/lib/yorso/uploads
YORSO_MAX_UPLOAD_BYTES=8388608
S3_ENDPOINT=http://minio:9000
S3_REGION=local
S3_BUCKET=yorso-production
S3_ACCESS_KEY_ID=change-me-production-storage-user
S3_SECRET_ACCESS_KEY=change-me-production-storage-secret

# Auth/session secrets. Generate unique 32+ byte values per environment.
YORSO_SESSION_SECRET=change-me-production-session-secret-32-bytes-minimum
YORSO_JWT_SECRET=change-me-production-jwt-secret-32-bytes-minimum
