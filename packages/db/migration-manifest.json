{
  "package": "@yorso/db",
  "productionTarget": "self-hosted-postgresql",
  "supabaseRole": "prototype-reference-only",
  "migrations": [
    {
      "id": "0000_migration_registry",
      "file": "migrations/0000_migration_registry.sql",
      "description": "Create the self-hosted YORSO migration registry table.",
      "ownedTables": ["_yorso_migrations"],
      "dependsOn": []
    },
    {
      "id": "0001_account_company_baseline",
      "file": "migrations/0001_account_company_baseline.sql",
      "description": "Create user, company and company media baseline tables for the self-hosted account API.",
      "ownedTables": ["yorso_users", "yorso_companies", "yorso_company_media"],
      "dependsOn": ["0000_migration_registry"]
    },
    {
      "id": "0002_account_workspace_sections",
      "file": "migrations/0002_account_workspace_sections.sql",
      "description": "Create branches, products, meta-regions and notification preferences for the self-hosted account workspace.",
      "ownedTables": [
        "yorso_company_branches",
        "yorso_company_products",
        "yorso_company_meta_regions",
        "yorso_notification_preferences"
      ],
      "dependsOn": ["0001_account_company_baseline"]
    }
  ]
}
